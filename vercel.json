{
  "version": 2,
  "buildCommand": "echo 'no build'",
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/index.html", "dest": "index.html" },
    { "src": "/pricing.html", "dest": "index.html" },
    { "src": "/trial.html", "dest": "oryntech-trial.html" },
    { "src": "/tutorials.html", "dest": "oryntech-tutorials.html" },
    { "src": "/admin.html", "dest": "oryntech-admin.html" },
    { "src": "/editor.html", "dest": "oryntech-editor.html" },
    { "src": "/trial", "dest": "oryntech-trial.html" },
    { "src": "/tutorials", "dest": "oryntech-tutorials.html" },
    { "src": "/admin", "dest": "oryntech-admin.html" },
    { "src": "/editor", "dest": "oryntech-editor.html" },
    { "src": "/", "dest": "index.html" },
    { "src": "/(.*)", "dest": "$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
