# ─── SUPABASE ───────────────────────────────────────────
# Găsești în: supabase.com → proiect → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SERVICE_KEY (nu anon key!) — are acces complet, NU îl expune în frontend

# ─── JWT ────────────────────────────────────────────────
# Generează un string random de 64+ caractere
# ex: openssl rand -hex 64
JWT_SECRET=schimba_asta_cu_un_string_random_lung_de_minim_64_caractere

# ─── GHL WEBHOOK ────────────────────────────────────────
# Din GoHighLevel: Settings → Integrations → Webhooks
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/XXXXXXXX/webhook-trigger/XXXXXXXX

# ─── ADMIN ──────────────────────────────────────────────
# Primul cont admin — setat o singură dată la setup
ADMIN_SETUP_KEY=cheie_secreta_pentru_primul_setup

# ─── ENV ────────────────────────────────────────────────
NODE_ENV=development
